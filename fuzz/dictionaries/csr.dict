zero_i64="\x00\x00\x00\x00\x00\x00\x00\x00"
one_i64="\x01\x00\x00\x00\x00\x00\x00\x00"
two_i64="\x02\x00\x00\x00\x00\x00\x00\x00"
big_i64="\xff\xff\xff\xff\xff\xff\xff\x7f"
one_i32="\x01\x00\x00\x00"
f32_one="\x00\x00\x80\x3f"
