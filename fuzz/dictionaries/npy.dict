# libFuzzer dictionary for the NumPy .npy binary format.
# Magic + version prefix and the header-dict tokens the reader parses.
magic="\x93NUMPY"
v1="\x93NUMPY\x01\x00"
v2="\x93NUMPY\x02\x00"
v3="\x93NUMPY\x03\x00"
descr="'descr'"
fortran="'fortran_order'"
shape="'shape'"
f4="'<f4'"
f8="'<f8'"
true="True"
false="False"
open_brace="{"
close_brace="}"
open_paren="("
close_paren=")"
comma=", "
colon=": "
newline="\x0a"
